{
  "name": "@swarmx/core",
  "version": "3.1.0",
  "description": "Core SwarmX multi-agent runtime and platform contracts.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rendering": {
      "types": "./dist/rendering.d.ts",
      "import": "./dist/rendering.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry.d.ts",
      "import": "./dist/telemetry.js"
    },
    "./dependencies": {
      "types": "./dist/dependencies.d.ts",
      "import": "./dist/dependencies.js"
    },
    "./conversation": {
      "types": "./dist/conversation.d.ts",
      "import": "./dist/conversation.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "import": "./dist/providers.js"
    },
    "./model-capabilities": {
      "types": "./dist/model-capabilities.d.ts",
      "import": "./dist/model-capabilities.js"
    },
    "./harness-management": {
      "types": "./dist/harness-management.d.ts",
      "import": "./dist/harness-management.js"
    },
    "./agent-profiles": {
      "types": "./dist/agent-profiles.d.ts",
      "import": "./dist/agent-profiles.js"
    },
    "./desktop-settings": {
      "types": "./dist/desktop-settings.d.ts",
      "import": "./dist/desktop-settings.js"
    },
    "./secrets": {
      "types": "./dist/secrets.d.ts",
      "import": "./dist/secrets.js"
    },
    "./actions": {
      "types": "./dist/actions.d.ts",
      "import": "./dist/actions.js"
    },
    "./skill-variants": {
      "types": "./dist/skill-variants.d.ts",
      "import": "./dist/skill-variants.js"
    },
    "./extension-management": {
      "types": "./dist/extension-management.d.ts",
      "import": "./dist/extension-management.js"
    },
    "./project": {
      "types": "./dist/project.d.ts",
      "import": "./dist/project.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.22.0",
    "@anthropic-ai/sdk": "^0.111.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cel-js": "^0.8.0",
    "openai": "^6.39.0",
    "smol-toml": "^1.7.0",
    "uuid": "^11.0.0",
    "yaml": "^2.9.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
