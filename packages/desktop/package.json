{
  "name": "@swarmx/desktop",
  "version": "3.1.5",
  "description": "Electron desktop host and reusable renderer shell for SwarmX.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tcztzy/swarmx.git",
    "directory": "packages/desktop"
  },
  "type": "module",
  "main": "./out/main/index.js",
  "files": [
    "out",
    "dist/main",
    "dist/preload",
    "dist/renderer",
    "dist/shared",
    "build",
    "src/renderer/src/assets/styles.css",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    "third_party_licenses"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./out/main/index.js",
    "./package.json": "./package.json",
    "./main": {
      "types": "./dist/main/library.d.ts",
      "import": "./out/main/library.js"
    },
    "./preload": {
      "types": "./dist/preload/api.d.ts",
      "import": "./out/preload/api.mjs"
    },
    "./renderer": {
      "types": "./dist/renderer/App.d.ts",
      "import": "./dist/renderer/App.js"
    },
    "./styles.css": "./src/renderer/src/assets/styles.css"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && tsc -p tsconfig.renderer-lib.json && tsc -p tsconfig.main-lib.json && tsc -p tsconfig.preload-lib.json",
    "dist:mac": "pnpm build && node scripts/build-macos-artifacts.mjs",
    "preview": "electron-vite preview",
    "start": "electron .",
    "test": "vitest run"
  },
  "dependencies": {
    "@swarmx/core": "workspace:*",
    "@swarmx/runtime": "workspace:*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "node-pty": "^1.1.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.3.1",
    "swr": "^2.4.1",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
