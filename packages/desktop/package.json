{
  "name": "@swarmx/desktop",
  "version": "3.0.0",
  "description": "Electron desktop host and reusable renderer shell for SwarmX.",
  "license": "MIT",
  "type": "module",
  "main": "./out/main/index.js",
  "files": ["out", "dist/renderer", "src/renderer/src/assets/styles.css"],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./out/main/index.js",
    "./renderer": {
      "types": "./dist/renderer/App.d.ts",
      "import": "./dist/renderer/App.js"
    },
    "./styles.css": "./src/renderer/src/assets/styles.css"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && tsc -p tsconfig.renderer-lib.json",
    "preview": "electron-vite preview",
    "start": "electron .",
    "test": "vitest run"
  },
  "dependencies": {
    "@swarmx/core": "workspace:*",
    "katex": "^0.17.0",
    "lucide-react": "^1.17.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shiki": "^4.3.1",
    "swr": "^2.4.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^33.0.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
